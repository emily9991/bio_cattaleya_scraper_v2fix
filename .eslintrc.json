{
  "root": true,
  "env": {
    "browser": true,
    "es2021": true,
    "webextensions": true
  },
  "parserOptions": {
    "ecmaVersion": 2021
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "warn",
    "no-undef": "warn"
  },
  "overrides": [
    {
      "files": ["server/**/*.js", "debug_server/**/*.js", "webpack.config.js"],
      "env": { "node": true, "browser": false }
    },
    {
      "files": ["**/background.js"],
      "globals": {
        "importScripts": "readonly",
        "chrome": "readonly"
      }
    },
    {
      "files": ["**/content.js", "**/popup.js", "**/background.js"],
      "globals": {
        "chrome": "readonly",
        "CONFIG": "readonly",
        "bscLog": "readonly",
        "mostrarNotificacion": "readonly",
        "secureStorage": "readonly",
        "extraerPrecioCard": "readonly",
        "detenerListingObserver": "readonly",
        "listingItems": "readonly",
        "listingUrls": "readonly"
      }
    }
  ]
}
