# Copia este archivo como .env (misma carpeta que receptor_biocattaleya.py o en C:\taobao_scraper\.env)
# Integración: https://www.notion.so/my-integrations

NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Nombres de propiedades en tu base de datos Notion (deben coincidir exactamente)
NOTION_PROP_TITLE=Nombre
NOTION_PROP_URL=URL Taobao
NOTION_PROP_CNY=Precio CNY
NOTION_PROP_USD=Precio USD
NOTION_PROP_CAT=Categoría

# Backend y servidor local (desarrollo)
BACKEND_URL=https://localhost:3000
PYTHON_SERVER=http://127.0.0.1:5000

# Configuración de licencia (desarrollo)
LICENSE_KEY=dev_license_key_placeholder

# URLs de servicios (solo referencia - se cargan desde src/config.js)
# GOOGLE_TRANSLATE_URL=https://translate.googleapis.com/translate_a/single?client=gtx&sl=zh-CN&tl=en&dt=t&q=

# Opcional: desactivar envío a Notion (1 = no enviar)
# NOTION_DISABLE=0
