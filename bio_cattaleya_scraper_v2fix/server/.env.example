# ============================================================
# CONFIGURACIÓN DEL SERVIDOR BACKEND - ARCHIVO SENSIBLE
# ============================================================
# Copia este archivo como .env en la misma carpeta server/
# NO SUBIR .env A REPOSITORIOS

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long
JWT_EXPIRES_IN=24h

# Notion API Integration
# Obtén estos valores desde: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Nombres de propiedades en tu base de datos Notion (deben coincidir exactamente)
NOTION_PROP_TITLE=Nombre
NOTION_PROP_URL=URL Taobao
NOTION_PROP_CNY=Precio CNY
NOTION_PROP_USD=Precio USD
NOTION_PROP_CAT=Categoría

# Server Configuration
PORT=3000
NODE_ENV=development

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100  # requests per window

# CORS Configuration
ALLOWED_ORIGINS=chrome-extension://*,http://localhost:3000,https://localhost:3000

# Opcional: desactivar envío a Notion (1 = no enviar)
# NOTION_DISABLE=0
