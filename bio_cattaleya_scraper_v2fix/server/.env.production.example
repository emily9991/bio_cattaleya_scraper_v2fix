# ============================================================
# CONFIGURACIÓN DEL SERVIDOR BACKEND - PLANTILLA PRODUCCIÓN
# ============================================================
# Copia este archivo como .env.production en la misma carpeta server/
# Reemplaza los placeholders con tus valores reales
# NO SUBIR EL .env.production REAL A REPOSITORIOS

# JWT Configuration - Genera 64 caracteres aleatorios para producción
JWT_SECRET=your_jwt_secret_minimum_64_characters_long_for_production_security

# Notion API Integration
NOTION_TOKEN=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here

# Nombres de propiedades en tu base de datos Notion (deben coincidir exactamente)
NOTION_PROP_TITLE=Nombre
NOTION_PROP_URL=URL Taobao
NOTION_PROP_CNY=Precio CNY
NOTION_PROP_USD=Precio USD
NOTION_PROP_CAT=Categoría

# Server Configuration
PORT=3000
NODE_ENV=production

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100  # requests per window

# CORS Configuration
ALLOWED_ORIGINS=chrome-extension://*,http://localhost:3000,https://localhost:3000

# Opcional: desactivar envío a Notion (1 = no enviar)
# NOTION_DISABLE=0
