{
  "manifest_version": 3,
  "name": "Bio Cattaleya Scraper",
  "version": "2.0.0",
  "description": "Extrae información de productos mediante web scraping y la envía al receptor Python.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Bio Cattaleya Scraper",
    "default_icon": {
      "16": "lib/icons/icon16.png",
      "48": "lib/icons/icon48.png",
      "128": "lib/icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "lib/icons/icon16.png",
    "48": "lib/icons/icon48.png",
    "128": "lib/icons/icon128.png"
  }
}
